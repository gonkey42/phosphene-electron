{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "fs:default",
    "fs:scope-appdata-recursive",
    "fs:allow-home-read-recursive",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-copy-file",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "http:default",
    "shell:allow-open",
    "updater:default"
  ]
}
